{
  "name": "telegram-notifier",
  "version": "1.0.0",
  "description": "Get Telegram notifications when Claude needs approval, asks questions, or finishes tasks",
  "author": {
    "name": "Lucas",
    "email": ""
  },
  "license": "MIT",
  "homepage": "https://github.com/herbalclaw/need-follow-up",
  "repository": "https://github.com/herbalclaw/need-follow-up",
  "keywords": ["telegram", "notifications", "approval", "mobile", "alerts"],
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-permission.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-stop.sh"
          }
        ]
      }
    ]
  }
}
